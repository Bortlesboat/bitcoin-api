# Staging environment — Azure Cloud Sprint
# Copy to .env.staging and fill in values

# Bitcoin RPC (points back to Main PC via Cloudflare Tunnel)
BITCOIN_RPC_HOST=your-tunnel.trycloudflare.com
BITCOIN_RPC_PORT=8332
BITCOIN_RPC_USER=satoshi
BITCOIN_RPC_PASSWORD=your-rpc-password

# AI Features (priority: Azure OpenAI > OpenAI > Ollama)
ENABLE_AI_FEATURES=true

# Azure OpenAI (Sprint 2)
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
AZURE_OPENAI_KEY=your-key
AZURE_OPENAI_DEPLOYMENT=gpt-4o-mini

# Ollama fallback (Mac Mini — used after Azure credits expire)
# OLLAMA_URL=http://192.168.1.238:11434
# OLLAMA_MODEL=qwen2.5:14b

# PostgreSQL indexer (Azure Flexible Server or local)
ENABLE_INDEXER=true
INDEXER_POSTGRES_DSN=postgresql://satoshi:password@your-server.postgres.database.azure.com:5432/satoshi_index?sslmode=require

# OpenTelemetry / Application Insights
# APPLICATIONINSIGHTS_CONNECTION_STRING=InstrumentationKey=xxx;IngestionEndpoint=https://eastus-8.in.applicationinsights.azure.com/

# API
CORS_ORIGINS=*
